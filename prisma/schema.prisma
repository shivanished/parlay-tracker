generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Parlay {
  id              String   @id @default(cuid())
  userId          String
  createdAt       DateTime @default(now())
  status          String   @default("active")
  wagerAmount     Float?
  totalOdds       Float?
  potentialPayout Float?
  screenshotUrl   String?
  legs            Leg[]

  @@index([userId])
}

model Leg {
  id          String  @id @default(cuid())
  parlayId    String
  parlay      Parlay  @relation(fields: [parlayId], references: [id], onDelete: Cascade)
  team        String
  opponent    String
  league      String  @default("NBA")
  betType     String
  line        String
  odds        Int
  status      String  @default("pending")
  espnEventId String?
  finalStatValue  Float?
  targetStatValue Float?
  statLabel       String?
  gameHomeTeam  String?
  gameAwayTeam  String?
  gameHomeScore Int?
  gameAwayScore Int?
  gamePeriod    String?
  gameCompleted Boolean?
}
